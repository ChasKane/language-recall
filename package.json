{
  "name": "language-recall",
  "version": "1.0.9",
  "description": "Add anki-like spaced repetition and recall to your vault with built-in language translation.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint src package.json",
    "release": "mkdir -p dist && mv main.js dist/ && cp src/styles.css dist/ && cp manifest.json dist/ && pnpm version"
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChasKane/language-recall.git"
  },
  "author": "Chas Kane",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "esbuild": "0.25.11",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "eslint-plugin-prettier": "^5.5.4",
    "obsidian": "1.10.0",
    "prettier": "^3.6.2",
    "tslib": "2.8.1",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=9.0.7",
      "picomatch": ">=4.0.4"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-2g4f-4pwh-qvx6"
      ]
    }
  }
}
